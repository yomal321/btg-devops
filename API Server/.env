# ========================================
# API Server - Environment Variables
# ========================================

# --- Database (local pgAdmin) ---
$env:DATABASE_URL="postgresql://postgres:yomal@8899@localhost:5432/btg_devops"

# --- JWT Secret (use any long random string) ---
$env:JWT_SECRET="So1jWr/TROANt+GhkCIoePOs2Q8WLXNTrlj6Syd65Mw="


# --- Server Port (optional, defaults to 8080) ---
$env:PORT="8080"

# ========================================
# Useful Commands
# ========================================

# Run the API server
# go run .

# Test health check
# Invoke-RestMethod -Uri "http://localhost:8080/health" -Method GET

# Test login
# Invoke-RestMethod -Uri "http://localhost:8080/auth/login" -Method POST -ContentType "application/json" -Body '{"email":"admin@bistecglobal.com","password":"admin1234"}'

# List audits (replace TOKEN with value from login response)
# Invoke-RestMethod -Uri "http://localhost:8080/audits" -Method GET -Headers @{Authorization="Bearer TOKEN"}
